{
	"schemaVersion": 1,
	"id": "bgal",
	"version": "${version}",
	"name": "BetterGrassAndLeaves",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Poersch",
		"Xy_Luce"
	],
	"contact": {
		"homepage": "https://minecraftistooeasy.github.io/",
		"sources": "https://github.com/MinecraftIsTooEasy/fish-example-mod"
	},
	"icon": "assets/bettergrassandleaves/textures/icon.png",
	"environment": "client",
	"entrypoints": {
		"preLaunch": [
			"net.moddedmite.bettergarassandleaves.BGALEarlyRiser"
		],
		"client": [
			"poersch.minecraft.bettergrassandleaves.BetterGrassAndLeavesMod"
		]
	},
	"mixins": [
		"bgal.mixins.json"
	],
	"accessWidener": "bgal.accesswidener",
	"depends": {
		"fishmodloader": ">=3.4.0",
		"minecraft": "1.6.4-mite",
		"java": ">=17",
		"rusted_iron_core": ">=1.3.5",
		"forge_config": ">=0.0.1"
	},
	"custom": {
		"loom:injected_interfaces": {
			"net/minecraft/BlockLeaves": [
				"poersch/minecraft/bettergrassandleaves/interfaces/IBetterLeaves"
			]
		}
	}
}